# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here

# MIMO SETTINGS (OpenAI-compatible token-plan endpoint)
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_THINKING=enabled
MIMO_MAX_COMPLETION_TOKENS=32768
MIMO_TEMPERATURE=1.0
MIMO_TOP_P=0.95

# LOCAL LLM SETTINGS (GGUF via llama-cpp)
# Download model from: https://huggingface.co/microsoft/Phi-3-mini-4k-instruct-gguf
LOCAL_MODEL_PATH=./models/Phi-3-mini-4k-instruct-q4.gguf

# LAB CONFIG
# Options: openai | google | local | mimo
DEFAULT_PROVIDER=mimo
DEFAULT_MODEL=mimo-v2.5-pro
LOG_LEVEL=INFO
